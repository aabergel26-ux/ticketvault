{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "composite": true
  },
  "files": ["server/gmailParser.ts", "server/db.ts", "server/session.ts", "server/rateLimit.ts"],
  "include": ["src/types/index.ts"]
}
